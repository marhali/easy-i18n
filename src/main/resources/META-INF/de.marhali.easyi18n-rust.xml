<idea-plugin>
  <extensions defaultExtensionNs="com.intellij">
    <psi.referenceContributor
      language="Rust"
      implementation="de.marhali.easyi18n.idea.assistance.rust.RustI18nPsiReferenceContributor"
    />

    <completion.contributor
      language="Rust"
      implementationClass="de.marhali.easyi18n.idea.assistance.rust.RustI18nCompletionContributor"
    />

    <platform.backend.documentation.targetProvider
      implementation="de.marhali.easyi18n.idea.assistance.rust.RustI18nDocumentationTargetProvider"
    />

    <lang.foldingBuilder
      language="Rust"
      implementationClass="de.marhali.easyi18n.idea.assistance.rust.RustI18nFoldingBuilder"
    />

    <localInspection
      language="Rust"
      shortName="UnresolvedI18nKeyRust"
      enabledByDefault="true"
      level="ERROR"
      implementationClass="de.marhali.easyi18n.idea.assistance.rust.RustI18nKeyLocalInspection"
      bundle="messages.PluginBundle"
      groupKey="editor.intention.family"
      key="editor.intention.unresolved.title"
    />

    <intentionAction>
      <className>de.marhali.easyi18n.idea.assistance.rust.RustExtractTranslationIntention</className>
      <language>Rust</language>
      <bundleName>messages.PluginBundle</bundleName>
      <skipBeforeAfter>true</skipBeforeAfter>
      <categoryKey>editor.intention.family</categoryKey>
      <descriptionDirectoryName>extract</descriptionDirectoryName>
    </intentionAction>
  </extensions>
</idea-plugin>
