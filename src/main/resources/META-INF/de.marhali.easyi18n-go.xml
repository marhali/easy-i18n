<idea-plugin>
  <extensions defaultExtensionNs="com.intellij">
    <psi.referenceContributor
      language="go"
      implementation="de.marhali.easyi18n.idea.assistance.go.GoI18nPsiReferenceContributor"
    />

    <completion.contributor
      language="go"
      implementationClass="de.marhali.easyi18n.idea.assistance.go.GoI18nCompletionContributor"
    />

    <platform.backend.documentation.targetProvider
      implementation="de.marhali.easyi18n.idea.assistance.go.GoI18nDocumentationTargetProvider"
    />

    <lang.foldingBuilder
      language="go"
      implementationClass="de.marhali.easyi18n.idea.assistance.go.GoI18nFoldingBuilder"
    />

    <localInspection
      language="go"
      shortName="UnresolvedI18nKeyGo"
      enabledByDefault="true"
      level="ERROR"
      implementationClass="de.marhali.easyi18n.idea.assistance.go.GoI18nKeyLocalInspection"
      bundle="messages.PluginBundle"
      groupKey="editor.intention.family"
      key="editor.intention.unresolved.title"
    />

    <intentionAction>
      <className>de.marhali.easyi18n.idea.assistance.go.GoExtractTranslationIntention</className>
      <language>go</language>
      <bundleName>messages.PluginBundle</bundleName>
      <skipBeforeAfter>true</skipBeforeAfter>
      <categoryKey>editor.intention.family</categoryKey>
      <descriptionDirectoryName>extract</descriptionDirectoryName>
    </intentionAction>
  </extensions>
</idea-plugin>
