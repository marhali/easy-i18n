<idea-plugin>
  <extensions defaultExtensionNs="com.intellij">
    <psi.referenceContributor
      language="Python"
      implementation="de.marhali.easyi18n.idea.assistance.python.PythonI18nPsiReferenceContributor"
    />

    <completion.contributor
      language="Python"
      implementationClass="de.marhali.easyi18n.idea.assistance.python.PythonI18nCompletionContributor"
    />

    <platform.backend.documentation.targetProvider
      implementation="de.marhali.easyi18n.idea.assistance.python.PythonI18nDocumentationTargetProvider"
    />

    <lang.foldingBuilder
      language="Python"
      implementationClass="de.marhali.easyi18n.idea.assistance.python.PythonI18nFoldingBuilder"
    />

    <localInspection
      language="Python"
      shortName="UnresolvedI18nKeyPython"
      enabledByDefault="true"
      level="ERROR"
      implementationClass="de.marhali.easyi18n.idea.assistance.python.PythonI18nKeyLocalInspection"
      bundle="messages.PluginBundle"
      groupKey="editor.intention.family"
      key="editor.intention.unresolved.title"
    />

    <intentionAction>
      <className>de.marhali.easyi18n.idea.assistance.python.PythonExtractTranslationIntention</className>
      <language>Python</language>
      <bundleName>messages.PluginBundle</bundleName>
      <skipBeforeAfter>true</skipBeforeAfter>
      <categoryKey>editor.intention.family</categoryKey>
      <descriptionDirectoryName>extract</descriptionDirectoryName>
    </intentionAction>
  </extensions>
</idea-plugin>
