<messages>

  <!--
    Property value (rule-06: key attribute on <message> elements).
    The value of key is treated as an i18n key.
    Folding, hover documentation, Ctrl+Click reference, and completion work
    on the attribute value.
  -->

  <!-- Resolved keys → folding, hover documentation, and Ctrl+Click reference work -->
  <message key="common:primitive.string.sample" />
