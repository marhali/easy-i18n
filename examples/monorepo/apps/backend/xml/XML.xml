  <message key="billing:object.deeply.nested.structure.description" />
  <message key="common:object.hybrid\.flat\.structure" />

  <!-- Unresolved keys → inspection error -->
  <message key="common:does.not.exist" />
  <message key="user:unknown.key" />

</messages>
